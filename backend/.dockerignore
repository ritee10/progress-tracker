# .dockerignore — Exclude files from Docker build context
# This prevents .env secrets, dev tools, test files, and cache
# from being baked into the production image.

# Environment / secrets
.env
.env.*
!.env.example

# Version control
.git
.gitignore

# Python cache
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Test files (not needed in production image)
tests/
pytest.ini
setup.cfg
conftest.py
.pytest_cache/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo

# Docker files (no need to include themselves)
Dockerfile
docker-compose*.yml

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
